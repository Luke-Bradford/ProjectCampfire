# Database
DATABASE_URL="postgresql://campfire:campfire@localhost:5432/campfire"

# Redis (Valkey)
REDIS_URL="redis://localhost:6379"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# MinIO (Object Storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="campfire"
# Set when MINIO_ENDPOINT is a Docker-internal hostname not reachable by browsers.
# e.g. when running in Docker: MINIO_PUBLIC_URL="http://localhost:9000/campfire"
# MINIO_PUBLIC_URL=""
# Set to true only when MinIO itself serves TLS (not when TLS is terminated by a proxy).
# MINIO_USE_SSL="false"

# Email — Mailhog in dev, set real SMTP for prod
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@campfire.local"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Skip env validation during Docker build
# SKIP_ENV_VALIDATION=true

# Web Push (VAPID) — optional. When set, browser push notifications are enabled.
# Generate keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@example.com"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""   # must equal VAPID_PUBLIC_KEY

# Phase 2 — leave blank until needed
# IGDB_CLIENT_ID=""
# IGDB_CLIENT_SECRET=""
# STEAM_API_KEY=""

# Tenor GIF API (optional — when set, the GIF picker is enabled in the post composer)
# Get a free key at https://developers.google.com/tenor/guides/quickstart
# TENOR_API_KEY=""

# Logging (optional — defaults to "info"; set to "debug" for verbose output)
# LOG_LEVEL="info"

# Social OAuth (optional — uncomment and fill in to enable social login buttons)
# Callback URL to register in each provider's dashboard:
#   Google:  {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
#   Discord: {NEXT_PUBLIC_APP_URL}/api/auth/callback/discord
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="true"
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""
# NEXT_PUBLIC_DISCORD_OAUTH_ENABLED="true"
