{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Kill port 3000",
      "type": "shell",
      "command": "powershell -Command \"$p = Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess; if ($p) { Stop-Process -Id $p -Force -ErrorAction SilentlyContinue; Start-Sleep 1 }; Write-Host 'Port 3000 clear'\"",
      "isBackground": false,
      "presentation": {
        "group": "devservers",
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Next.js dev server",
      "type": "shell",
      "command": "pnpm dev",
      "dependsOn": ["Kill port 3000"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "line": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting\\.\\.\\.",
          "endsPattern": "Ready in"
        }
      },
      "presentation": {
        "group": "devservers",
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "BullMQ worker",
      "type": "shell",
      "command": "pnpm worker",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "devservers",
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start dev",
      "dependsOn": ["Next.js dev server", "BullMQ worker"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
