{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start dev stack",
      "type": "shell",
      "command": "powershell -File scripts/dev-start.ps1",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "line": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "==>",
          "endsPattern": "Dev stack is ready"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
