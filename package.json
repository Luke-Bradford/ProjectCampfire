  "pnpm": {
    "overrides": {
      "ioredis": "^5.10.0"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^20.17.0",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
